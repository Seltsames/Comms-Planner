# =============================================================================
# DiDi CommsPlanner — local environment variables
# =============================================================================
# Copy this file's contents into `.env.local` (git-ignored) and fill in your
# real Supabase project values. Vite only exposes variables prefixed with
# VITE_ to the client bundle.
# =============================================================================

# Supabase project URL — find it in Supabase Studio → Settings → API
VITE_SUPABASE_URL=

# Supabase publishable key (preferred) — Settings → API → "Publishable key".
# If your project predates publishable keys, the legacy "anon" JWT works too:
# copy the `anon` `public` key and put it here.
VITE_SUPABASE_PUBLISHABLE_KEY=
